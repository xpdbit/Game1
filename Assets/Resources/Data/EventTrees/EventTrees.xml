<?xml version="1.0" encoding="UTF-8"?>
<EventTrees>
    <!-- 商队事件 -->
    <EventTree>
        <id>Core.EventTree.MerchantEncounter</id>
        <name>路遇商队</name>
        <description>旅行途中遇到一支商队，可以选择交易或聊天</description>
        <rootNodeId>node_1</rootNodeId>
        <nodes>
            <Node>
                <id>node_1</id>
                <type>Root</type>
                <title>商队领队</title>
                <description>你好，旅行者！我这里有些稀奇的货物，从远处带来的...</description>
                <isOptional>false</isOptional>
                <choices>
                    <Choice>
                        <id>buy</id>
                        <text>看看有什么货物</text>
                        <nextNodeId>node_2</nextNodeId>
                        <goldCost>30</goldCost>
                    </Choice>
                    <Choice>
                        <id>talk</id>
                        <text>聊聊旅途见闻</text>
                        <nextNodeId>node_3</nextNodeId>
                        <setFlag>talked_to_merchant</setFlag>
                    </Choice>
                    <Choice>
                        <id>leave</id>
                        <text>婉言谢绝，继续赶路</text>
                        <nextNodeId></nextNodeId>
                    </Choice>
                </choices>
            </Node>
            <Node>
                <id>node_2</id>
                <type>Choice</type>
                <title>挑选货物</title>
                <description>这些是上好的丝绸和香料，还有这把锋利的匕首...</description>
                <isOptional>false</isOptional>
                <choices>
                    <Choice>
                        <id>buy_silk</id>
                        <text>购买丝绸</text>
                        <nextNodeId>node_4</nextNodeId>
                        <goldCost>50</goldCost>
                        <setFlag>bought_silk</setFlag>
                    </Choice>
                    <Choice>
                        <id>buy_dagger</id>
                        <text>购买匕首</text>
                        <nextNodeId>node_4</nextNodeId>
                        <goldCost>40</goldCost>
                        <addModuleIds>
                            <moduleId>Core.Item.ShortBlade</moduleId>
                        </addModuleIds>
                    </Choice>
                    <Choice>
                        <id>just_leave</id>
                        <text>算了，都不需要</text>
                        <nextNodeId></nextNodeId>
                    </Choice>
                </choices>
            </Node>
            <Node>
                <id>node_3</id>
                <type>Choice</type>
                <title>旅途见闻</title>
                <description>哦？你也去过那些地方吗？我听说前面那座山里最近有宝藏出现...</description>
                <isOptional>false</isOptional>
                <choices>
                    <Choice>
                        <id>ask_more</id>
                        <text>宝藏？详细说说</text>
                        <nextNodeId>node_5</nextNodeId>
                        <setFlag>learned_about_treasure</setFlag>
                    </Choice>
                    <Choice>
                        <id>say_goodbye</id>
                        <text>谢谢情报，再见</text>
                        <nextNodeId></nextNodeId>
                    </Choice>
                </choices>
            </Node>
            <Node>
                <id>node_4</id>
                <type>End</type>
                <title>交易完成</title>
                <description>成交！祝您旅途愉快！</description>
                <rewards>
                    <Effect>gold:+0</Effect>
                </rewards>
            </Node>
            <Node>
                <id>node_5</id>
                <type>End</type>
                <title>分别</title>
                <description>后会有期，旅行者！</description>
                <rewards>
                    <Effect>flag:set:merchant_friend</Effect>
                </rewards>
            </Node>
        </nodes>
    </EventTree>

    <!-- 遗迹探索事件 -->
    <EventTree>
        <id>Core.EventTree.AncientRuins</id>
        <name>神秘遗迹</name>
        <description>发现了一处被遗忘的神秘遗迹，可以选择探索或离开</description>
        <rootNodeId>node_1</rootNodeId>
        <nodes>
            <Node>
                <id>node_1</id>
                <type>Root</type>
                <title>遗迹入口</title>
                <description>古老的石门上刻满了神秘的符文，隐约散发着微弱的光芒...</description>
                <isOptional>false</isOptional>
                <choices>
                    <Choice>
                        <id>enter</id>
                        <text>推开石门进入探索</text>
                        <nextNodeId>node_2</nextNodeId>
                    </Choice>
                    <Choice>
                        <id>search</id>
                        <text>先在周围搜索一下</text>
                        <nextNodeId>node_3</nextNodeId>
                        <setFlag>searched_ruins_outside</setFlag>
                    </Choice>
                    <Choice>
                        <id>leave</id>
                        <text>这里太诡异了，还是离开</text>
                        <nextNodeId></nextNodeId>
                    </Choice>
                </choices>
            </Node>
            <Node>
                <id>node_2</id>
                <type>Choice</type>
                <title>遗迹内部</title>
                <description>内部布满了尘埃和蛛网，中央有一座祭坛，上面放着一件发光的物品...</description>
                <isOptional>false</isOptional>
                <choices>
                    <Choice>
                        <id>take_item</id>
                        <text>拿走祭坛上的物品</text>
                        <nextNodeId>node_4</nextNodeId>
                        <setFlag>took_artifact</setFlag>
                    </Choice>
                    <Choice>
                        <id>examine</id>
                        <text>仔细观察祭坛</text>
                        <nextNodeId>node_5</nextNodeId>
                    </Choice>
                    <Choice>
                        <id>retreat</id>
                        <text>感觉不对，立刻撤退</text>
                        <nextNodeId></nextNodeId>
                    </Choice>
                </choices>
            </Node>
            <Node>
                <id>node_3</id>
                <type>Choice</type>
                <title>外围搜索</title>
                <description>在遗迹外围发现了一些古老的石碑，上面似乎刻着某种警告...</description>
                <isOptional>false</isOptional>
                <choices>
                    <Choice>
                        <id>read_stone</id>
                        <text>阅读石碑上的文字</text>
                        <nextNodeId>node_6</nextNodeId>
                        <setFlag>read_warning</setFlag>
                    </Choice>
                    <Choice>
                        <id>enter_now</id>
                        <text>不管了，直接进去</text>
                        <nextNodeId>node_2</nextNodeId>
                    </Choice>
                </choices>
            </Node>
            <Node>
                <id>node_4</id>
                <type>End</type>
                <title>获得宝物</title>
                <description>你获得了一件古老的神秘遗物！它散发着温暖的光芒...</description>
                <rewards>
                    <Effect>gold:+100</Effect>
                    <Effect>item:Core.Item.AncientArtifact:1</Effect>
                </rewards>
            </Node>
            <Node>
                <id>node_5</id>
                <type>End</type>
                <title>发现秘密</title>
                <description>祭坛上刻着古老的铭文，记载着这件遗物的真正用途...</description>
                <rewards>
                    <Effect>gold:+50</Effect>
                    <Effect>flag:set:learned_artifact_secret</Effect>
                </rewards>
            </Node>
            <Node>
                <id>node_6</id>
                <type>End</type>
                <title>警告信息</title>
                <description>石碑上的文字警告说：擅自拿走遗物者将受到诅咒...</description>
                <rewards>
                    <Effect>flag:set:knows_curse</Effect>
                </rewards>
            </Node>
        </nodes>
    </EventTree>

    <!-- 旅店休息事件 -->
    <EventTree>
        <id>Core.EventTree.InnRest</id>
        <name>路旁旅店</name>
        <description>天色渐晚，发现了一家路边旅店，可以选择休息或继续赶路</description>
        <rootNodeId>node_1</rootNodeId>
        <nodes>
            <Node>
                <id>node_1</id>
                <type>Root</type>
                <title>旅店门口</title>
                <description>疲惫的旅人，这边请！我们的房间干净舒适，保证让您睡个好觉！</description>
                <isOptional>false</isOptional>
                <choices>
                    <Choice>
                        <id>rest</id>
                        <text>休息一晚</text>
                        <nextNodeId>node_2</nextNodeId>
                        <goldCost>20</goldCost>
                    </Choice>
                    <Choice>
                        <id>hear_story</id>
                        <text>先听听老板有什么故事</text>
                        <nextNodeId>node_3</nextNodeId>
                    </Choice>
                    <Choice>
                        <id>continue</id>
                        <text>谢谢，还是继续赶路吧</text>
                        <nextNodeId></nextNodeId>
                    </Choice>
                </choices>
            </Node>
            <Node>
                <id>node_2</id>
                <type>End</type>
                <title>一夜好梦</title>
                <description>充足的休息让您精神焕发！</description>
                <rewards>
                    <Effect>hp:+50</Effect>
                </rewards>
            </Node>
            <Node>
                <id>node_3</id>
                <type>Choice</type>
                <title>老板的故事</title>
                <description>说起来，最近这附近确实有些不太平，听说山里来了一伙强盗...</description>
                <isOptional>false</isOptional>
                <choices>
                    <Choice>
                        <id>ask_details</id>
                        <text>强盗？具体情况如何？</text>
                        <nextNodeId>node_4</nextNodeId>
                        <setFlag>learned_about_bandits</setFlag>
                    </Choice>
                    <Choice>
                        <id>rest_anyway</id>
                        <text>不管怎样还是先休息吧</text>
                        <nextNodeId>node_2</nextNodeId>
                        <goldCost>20</goldCost>
                    </Choice>
                </choices>
            </Node>
            <Node>
                <id>node_4</id>
                <type>End</type>
                <title>获得情报</title>
                <description>感谢您的情报！这些信息对旅人们很有帮助！</description>
                <rewards>
                    <Effect>gold:+10</Effect>
                    <Effect>flag:set:gossip_rewards</Effect>
                </rewards>
            </Node>
        </nodes>
    </EventTree>
</EventTrees>
